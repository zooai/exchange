# Zoo devnet — regulated provider wiring
#
# Addresses below come from `script/DeployProvider.s.sol` run against the
# Zoo devnet. To deploy your own provider, override these values.

NEXT_PUBLIC_RPC_URL=https://api.zoo-dev.network/rpc

# Regulated provider — default is the canonical adapter deployed to Zoo devnet.
NEXT_PUBLIC_LIQUIDITY_PROVIDER_ADAPTER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LIQUIDITY_PROVIDER_ROUTER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LIQUIDITY_PROVIDER_NAME=Liquidity.io
NEXT_PUBLIC_LIQUIDITY_PROVIDER_ONBOARDING_URL=https://onboard.liquidity.io
NEXT_PUBLIC_LIQUIDITY_PROVIDER_VERIFY_URL=https://verify.liquidity.io

# Pure-DeFi fallback: leave all LIQUIDITY_PROVIDER_* vars empty.
