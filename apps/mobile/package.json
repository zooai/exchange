{
  "name": "@zooai/exchange-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Zoo Exchange mobile — SDK consumer over @luxfi/mobile + @zooai/brand + @zooai/logo.",
  "license": "BSD-3-Clause",
  "scripts": {
    "start":    "expo start",
    "ios":      "expo run:ios",
    "android":  "expo run:android",
    "build:ios":     "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios":     "eas submit --platform ios --latest",
    "submit:android": "eas submit --platform android --latest"
  },
  "dependencies": {
    "@luxfi/mobile": "^1.0.0",
    "@zooai/brand": "^1.0.0",
    "@zooai/logo": "^1.0.0",
    "expo": "~51.0.0",
    "react": "^19.0.0",
    "react-native": "0.74.0"
  }
}
